# Template das variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais

# Configuração do Supabase (EXEMPLO - não são valores reais)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Como obter os valores:
# 1. Acesse: https://app.supabase.com
# 2. Selecione seu projeto  
# 3. Vá em Settings > API
# 4. SUPABASE_URL = Project URL
# 5. SUPABASE_SERVICE_ROLE_KEY = Secret keys > service_role ou sb_secret (SECRET!)
